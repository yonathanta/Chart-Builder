{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "type-check": "vue-tsc -b",
    "build": "vite build",
    "preview": "vite preview",
    "api:build": "dotnet build ChartBuilder/ChartBuilder.Api/ChartBuilder.Api.csproj -c Release",
    "db:migrations:list": "dotnet ef migrations list --no-build --configuration Release --project ChartBuilder/ChartBuilder.Infrastructure/ChartBuilder.Infrastructure.csproj --startup-project ChartBuilder/ChartBuilder.Api/ChartBuilder.Api.csproj --context ChartBuilder.Infrastructure.Persistence.AppDbContext",
    "db:migrations:list:identity": "dotnet ef migrations list --no-build --configuration Release --project ChartBuilder/ChartBuilder.Infrastructure/ChartBuilder.Infrastructure.csproj --startup-project ChartBuilder/ChartBuilder.Api/ChartBuilder.Api.csproj --context ChartBuilder.Infrastructure.Persistence.ApplicationDbContext",
    "db:migrations:check": "dotnet ef migrations has-pending-model-changes --no-build --configuration Release --project ChartBuilder/ChartBuilder.Infrastructure/ChartBuilder.Infrastructure.csproj --startup-project ChartBuilder/ChartBuilder.Api/ChartBuilder.Api.csproj --context ChartBuilder.Infrastructure.Persistence.AppDbContext",
    "db:migrations:check:identity": "dotnet ef migrations has-pending-model-changes --no-build --configuration Release --project ChartBuilder/ChartBuilder.Infrastructure/ChartBuilder.Infrastructure.csproj --startup-project ChartBuilder/ChartBuilder.Api/ChartBuilder.Api.csproj --context ChartBuilder.Infrastructure.Persistence.ApplicationDbContext",
    "db:update": "dotnet ef database update --no-build --configuration Release --project ChartBuilder/ChartBuilder.Infrastructure/ChartBuilder.Infrastructure.csproj --startup-project ChartBuilder/ChartBuilder.Api/ChartBuilder.Api.csproj --context ChartBuilder.Infrastructure.Persistence.AppDbContext",
    "db:update:identity": "dotnet ef database update --no-build --configuration Release --project ChartBuilder/ChartBuilder.Infrastructure/ChartBuilder.Infrastructure.csproj --startup-project ChartBuilder/ChartBuilder.Api/ChartBuilder.Api.csproj --context ChartBuilder.Infrastructure.Persistence.ApplicationDbContext"
  },
  "dependencies": {
    "@types/html2canvas": "^0.5.35",
    "axios": "^1.13.6",
    "canvg": "^4.0.3",
    "d3": "^7.9.0",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vue-tsc": "^3.1.4"
  }
}
